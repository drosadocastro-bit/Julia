# ============================================================
# Julia AI Crop Caretaker — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Home Assistant ---
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# --- OpenWeather API ---
# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Pushover Notifications (optional) ---
# Get keys at https://pushover.net/
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# --- Julia Config ---
# Path to plant profiles JSON
JULIA_PLANTS_CONFIG=julia/data/plants.json

# Log level: DEBUG, INFO, WARNING, ERROR
JULIA_LOG_LEVEL=INFO

# Dry run mode — decisions are logged but NOT executed
JULIA_DRY_RUN=false
